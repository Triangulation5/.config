# Vim-style half-page scrolling
goto_beginning go
goto_toc gO
screen_down <C-d>
screen_up <C-u>

# toggle_titlebar <C-w>
# prev_state <C-o> # Breaks config
# next_state <C-i> # Breaks config
zoom_in J
zoom_out K


# Toggle dark mode with 'i' (for "invert")
toggle_dark_mode I
toggle_custom_color C
# reload_config r # Breaks config
helper_window
toggle_fullscreen <A-return>

# fit_to_page_width s
